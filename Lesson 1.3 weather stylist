temper = float (input("Какая сейчас темпретару в градусах цельсия?"))
if temper < -20:
    print(f"Очень холодно, лучше остаться дома")
elif temper <= -1:
    print(f"Холодно, одевайся тепло!")
elif temper <= 15:
    print(f"Прохладно, возьми куртку")
elif temper <= 25:
    print(f"Тепло, можешь одеваться легко")
else: 
    print(f"Жарко, одень шорты!")
